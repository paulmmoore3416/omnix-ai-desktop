#!/bin/bash

# OMNIX Global Launcher - "dude" command
# This script launches the OMNIX AI Desktop Assistant with all services

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# ASCII Art Banner
echo -e "${CYAN}"
cat << "EOF"
   ____  __  __ _   _ _____  __
  / __ \|  \/  | \ | |_   _|/ /
 | |  | | \  / |  \| | | | | |  
 | |  | | |\/| | . ` | | | | |  
 | |__| | |  | | |\  |_| |_| |__
  \____/|_|  |_|_| \_|_____|____|
                                  
  Your God Mode AI Desktop Assistant
EOF
echo -e "${NC}"

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}🚀 Starting OMNIX...${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Function to check if a command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Function to check if a service is running
is_running() {
    pgrep -f "$1" >/dev/null 2>&1
}

# Step 1: Check prerequisites
echo -e "${YELLOW}📋 Checking prerequisites...${NC}"

if ! command_exists node; then
    echo -e "${RED}❌ Node.js is not installed${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Node.js $(node -v)${NC}"

if ! command_exists npm; then
    echo -e "${RED}❌ npm is not installed${NC}"
    exit 1
fi
echo -e "${GREEN}✓ npm $(npm -v)${NC}"

if ! command_exists cargo; then
    echo -e "${RED}❌ Rust/Cargo is not installed${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Rust $(rustc --version | cut -d' ' -f2)${NC}"

if ! command_exists ollama; then
    echo -e "${YELLOW}⚠ Ollama is not installed (optional for local AI)${NC}"
else
    echo -e "${GREEN}✓ Ollama installed${NC}"
fi

echo ""

# Step 2: Check and start Ollama if available
if command_exists ollama; then
    echo -e "${YELLOW}🤖 Checking Ollama service...${NC}"
    
    if ! is_running "ollama serve"; then
        echo -e "${YELLOW}Starting Ollama service...${NC}"
        ollama serve > /dev/null 2>&1 &
        sleep 2
        echo -e "${GREEN}✓ Ollama service started${NC}"
    else
        echo -e "${GREEN}✓ Ollama service already running${NC}"
    fi
    
    # Check if granite-code model is available
    if ollama list | grep -q "granite-code:8b"; then
        echo -e "${GREEN}✓ Granite Code 8B model available${NC}"
    else
        echo -e "${YELLOW}⚠ Granite Code 8B model not found${NC}"
        echo -e "${YELLOW}  Run: ollama pull granite-code:8b${NC}"
    fi
    echo ""
fi

# Step 3: Install dependencies if needed
if [ ! -d "node_modules" ]; then
    echo -e "${YELLOW}📦 Installing dependencies...${NC}"
    npm install
    echo -e "${GREEN}✓ Dependencies installed${NC}"
    echo ""
fi

# Step 4: Check environment configuration
if [ ! -f ".env" ]; then
    echo -e "${YELLOW}⚙️  Creating .env file from template...${NC}"
    cp .env.example .env
    echo -e "${GREEN}✓ .env file created${NC}"
    echo -e "${YELLOW}  Please configure your API keys in .env${NC}"
    echo ""
fi

# Step 5: Build and launch OMNIX
echo -e "${CYAN}🌌 Launching OMNIX AI Desktop Assistant...${NC}"
echo ""

# Check if we should run in dev or production mode
if [ "$1" == "--prod" ] || [ "$1" == "-p" ]; then
    echo -e "${YELLOW}Building for production...${NC}"
    npm run tauri build
    echo -e "${GREEN}✓ Build complete${NC}"
    echo -e "${CYAN}Run the built application from src-tauri/target/release/${NC}"
else
    echo -e "${YELLOW}Running in development mode...${NC}"
    echo -e "${CYAN}Press Ctrl+C to stop${NC}"
    echo ""
    npm run tauri dev
fi

